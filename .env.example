# Backend
DATABASE_URL=postgresql://localhost:5432/pulseboard
JWT_SECRET=generate-with-node -e "require('crypto').randomBytes(32).toString('hex')"
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174
FRONTEND_APP_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# Optional email settings for password reset delivery
RESEND_API_KEY=
RESET_EMAIL_FROM=onboarding@resend.dev
RESET_EMAIL_FROM_NAME=Pulseboard
ALLOW_SENDMAIL_FALLBACK=false
SENDMAIL_PATH=/usr/sbin/sendmail
