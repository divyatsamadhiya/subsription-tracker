generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BillingCycle {
  weekly
  monthly
  yearly
  custom_days
}

enum SubscriptionCategory {
  entertainment
  productivity
  utilities
  health
  other
}

enum ThemePreference {
  system
  light
  dark
}

enum UserRole {
  user
  admin
}

enum AdminAuditAction {
  user_soft_deleted
  user_restored
  user_force_logged_out
  user_role_granted
  user_role_revoked
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String?
  googleSubject          String?   @unique
  role                   UserRole  @default(user)
  sessionVersion         Int       @default(1)
  fullName               String?
  country                String?
  timeZone               String?
  phone                  String?
  bio                    String?
  avatarUrl              String?
  deletedAt              DateTime?
  deletedByAdminId       String?
  deleteReason           String?
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  settings      Settings?
  subscriptions Subscription[]

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Settings {
  id                   String          @id @default(uuid())
  userId               String          @unique
  defaultCurrency      String          @db.VarChar(3)
  weekStartsOn         Int             @default(0)
  notificationsEnabled Boolean         @default(false)
  themePreference      ThemePreference @default(system)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Subscription {
  pk                 String               @id @default(uuid())
  userId             String
  id                 String
  name               String
  amountMinor        Int
  currency           String               @db.VarChar(3)
  billingCycle       BillingCycle
  customIntervalDays Int?
  nextBillingDate    String
  category           SubscriptionCategory
  reminderDaysBefore Int[]
  isActive           Boolean              @default(true)
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  priceChanges PriceChange[]

  @@unique([userId, id])
  @@index([userId, nextBillingDate])
  @@map("subscriptions")
}

model PriceChange {
  id                 String       @id @default(uuid())
  subscriptionPk     String
  amountMinor        Int
  currency           String       @db.VarChar(3)
  billingCycle       BillingCycle
  customIntervalDays Int?
  effectiveDate      String
  createdAt          DateTime     @default(now())

  subscription Subscription @relation(fields: [subscriptionPk], references: [pk], onDelete: Cascade)

  @@index([subscriptionPk, effectiveDate])
  @@map("price_changes")
}

model AdminAuditLog {
  id          String           @id @default(uuid())
  adminUserId String
  targetUserId String?
  action      AdminAuditAction
  metadata    Json?
  createdAt   DateTime         @default(now())

  @@index([createdAt])
  @@index([adminUserId])
  @@index([targetUserId])
  @@map("admin_audit_logs")
}
